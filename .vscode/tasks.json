{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "pnpm: compile",
      "command": "pnpm run compile",
      "presentation": {
        "reveal": "silent"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Launch Extension Host (Insiders CLI)",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/.vscode/launch-extension-host.sh",
        "insiders",
        "9333",
        "${workspaceFolder}"
      ],
      "dependsOn": ["pnpm: compile"],
      "problemMatcher": []
    },
    {
      "label": "Launch Extension Host (Stable CLI)",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/.vscode/launch-extension-host.sh",
        "stable",
        "9334",
        "${workspaceFolder}"
      ],
      "dependsOn": ["pnpm: compile"],
      "problemMatcher": []
    }
  ]
}
