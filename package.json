{
  "name": "tokenguard-copilot",
  "displayName": "TokenGuard Copilot",
  "description": "Use third-party OpenAI-compatible models with VS Code Copilot Chat",
  "version": "0.1.0",
  "publisher": "ameshkov",
  "license": "MIT",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "enabledApiProposals": [
    "chatProvider"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "tokenguard-copilot",
        "displayName": "TokenGuard Copilot"
      }
    ],
    "commands": [
      {
        "command": "tokenguard-copilot.helloWorld",
        "title": "Hello World",
        "category": "TokenGuard Copilot"
      },
      {
        "command": "tokenguard-copilot.openSettings",
        "title": "Open Settings",
        "category": "TokenGuard Copilot"
      }
    ]
  },
  "scripts": {
    "compile": "pnpm run compile:extension && pnpm run compile:webview && pnpm run compile:migrations && pnpm run compile:e2e",
    "compile:extension": "pnpm --filter @tokenguard/extension run build",
    "compile:webview": "pnpm --filter @tokenguard/webview-ui run build",
    "compile:migrations": "mkdir -p out/db && cp -r packages/extension/src/db/migrations out/db/migrations",
    "compile:e2e": "tsc -p test-e2e/tsconfig.json",
    "typecheck": "pnpm -r run typecheck",
    "watch": "pnpm --filter @tokenguard/extension run watch",
    "watch:webview": "pnpm --filter @tokenguard/webview-ui run watch",
    "lint": "eslint && knip",
    "lint:fix": "eslint --fix",
    "format:check": "prettier --check --no-error-on-unmatched-pattern . && markdownlint-cli2 '**/*.md'",
    "format:fix": "prettier --write --no-error-on-unmatched-pattern . && markdownlint-cli2 --fix '**/*.md'",
    "prepare": "husky",
    "vscode:prepublish": "pnpm run compile",
    "package": "vsce package --no-dependencies -o dist/",
    "test": "pnpm -r run test",
    "test:extension": "pnpm --filter @tokenguard/extension run test",
    "test:webview": "pnpm --filter @tokenguard/webview-ui run test",
    "test:e2e": "pnpm run compile && vscode-test",
    "clean": "node -e \"const fs=require('node:fs');['out','packages/shared/dist','packages/extension/dist','packages/webview-ui/dist'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "clean:deps": "pnpm run clean && rm -rf node_modules packages/*/node_modules",
    "db:generate": "pnpm --filter @tokenguard/extension run db:generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/mocha": "10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^9.13.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "knip": "6.13.1",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.1.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "better-sqlite3",
      "esbuild",
      "keytar"
    ]
  }
}
