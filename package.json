{
  "name": "tokenguard-copilot",
  "displayName": "TokenGuard Copilot",
  "description": "Use third-party OpenAI-compatible models with VS Code Copilot Chat",
  "version": "1.2.6",
  "publisher": "adguard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ameshkov/tokenguard-copilot"
  },
  "bugs": {
    "url": "https://github.com/ameshkov/tokenguard-copilot/issues"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": {
      "supported": true
    }
  },
  "packageManager": "pnpm@10.28.1",
  "icon": "assets/icon/logo_256.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "enabledApiProposals": [
    "chatProvider",
    "languageModelSystem",
    "languageModelThinkingPart"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "tokenguard-copilot",
        "displayName": "TokenGuard Copilot"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "tokenguardCopilotChatDebugLogs",
          "name": "TokenGuard Logs",
          "when": "tokenguard-copilot.chatDebugEnabled",
          "icon": "$(output)"
        }
      ]
    },
    "commands": [
      {
        "command": "tokenguard-copilot.openSettings",
        "title": "Open Settings",
        "category": "TokenGuard Copilot"
      },
      {
        "command": "tokenguard-copilot.enableDebuggingLogging",
        "title": "Enable Debugging Logging",
        "category": "TokenGuard Copilot",
        "icon": "$(play)"
      },
      {
        "command": "tokenguard-copilot.disableDebuggingLogging",
        "title": "Disable Debugging Logging",
        "category": "TokenGuard Copilot",
        "icon": "$(stop)"
      },
      {
        "command": "tokenguard-copilot.clearDebuggingLogs",
        "title": "Clear Debugging Logs",
        "category": "TokenGuard Copilot",
        "icon": "$(trash)"
      },
      {
        "command": "tokenguard-copilot.refreshDebuggingLogs",
        "title": "Refresh Debugging Logs",
        "category": "TokenGuard Copilot",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tokenguard-copilot.disableDebuggingLogging",
          "when": "view == tokenguardCopilotChatDebugLogs",
          "group": "navigation",
          "icon": "$(stop)"
        },
        {
          "command": "tokenguard-copilot.clearDebuggingLogs",
          "when": "view == tokenguardCopilotChatDebugLogs",
          "group": "navigation",
          "icon": "$(trash)"
        },
        {
          "command": "tokenguard-copilot.refreshDebuggingLogs",
          "when": "view == tokenguardCopilotChatDebugLogs",
          "group": "navigation",
          "icon": "$(refresh)"
        }
      ]
    }
  },
  "scripts": {
    "compile": "pnpm run compile:shared && pnpm run compile:extension && pnpm run compile:webview && pnpm run compile:migrations && pnpm run compile:e2e",
    "compile:shared": "pnpm --filter @tokenguard/shared run build",
    "compile:extension": "pnpm --filter @tokenguard/extension run build",
    "compile:webview": "pnpm --filter @tokenguard/webview-ui run build",
    "compile:migrations": "rm -rf out/db/migrations && mkdir -p out/db && cp -r packages/extension/src/db/migrations out/db/migrations",
    "compile:e2e": "tsc -p test-e2e/tsconfig.json",
    "typecheck": "pnpm --filter @tokenguard/shared run build && pnpm -r run typecheck",
    "watch": "pnpm --filter @tokenguard/extension run watch",
    "watch:webview": "pnpm --filter @tokenguard/webview-ui run watch",
    "dev:webview": "pnpm --filter @tokenguard/webview-playground dev",
    "lint": "eslint && knip",
    "lint:fix": "eslint --fix",
    "format:check": "prettier --check --no-error-on-unmatched-pattern . && markdownlint-cli2 '**/*.md'",
    "format:fix": "prettier --write --no-error-on-unmatched-pattern . && markdownlint-cli2 --fix '**/*.md'",
    "prepare": "husky",
    "vscode:prepublish": "pnpm run compile",
    "package": "mkdir -p dist && vsce package --no-dependencies -o dist/",
    "test": "pnpm -r run test",
    "test:extension": "pnpm --filter @tokenguard/extension run test",
    "test:webview": "pnpm --filter @tokenguard/webview-ui run test",
    "test:e2e": "pnpm run compile && vscode-test",
    "clean": "node -e \"const fs=require('node:fs');['out','packages/shared/dist','packages/extension/dist','packages/webview-ui/dist','packages/shared/tsconfig.tsbuildinfo'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "clean:deps": "pnpm run clean && rm -rf node_modules packages/*/node_modules",
    "db:generate": "pnpm --filter @tokenguard/extension run db:generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/mocha": "10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^9.13.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "knip": "6.13.1",
    "markdownlint-cli2": "^0.22.1",
    "ovsx": "1.0.0",
    "prettier": "^3.1.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "better-sqlite3",
      "esbuild",
      "keytar"
    ]
  }
}
